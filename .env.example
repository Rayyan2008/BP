# Being Personalised Website - Environment Variables

# Supabase Configuration (Required for Admin Dashboard & Enquiries)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Email Configuration (Optional - for Enquiry Email Notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=hello@beingpersonalised.com

# Contact Information
NEXT_PUBLIC_WHATSAPP_NUMBER=+916398765432
NEXT_PUBLIC_PHONE_NUMBER=+44XXXXXXXXXXXXX
NEXT_PUBLIC_EMAIL_ADDRESS=hello@beingpersonalised.com
NEXT_PUBLIC_INSTAGRAM_HANDLE=@beingpersonalised
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/beingpersonalised

# Google Analytics (Optional - for Contact Tracking)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Vercel Analytics (Optional - Automatically integrated)
# No configuration needed - works out of the box

# Admin Configuration
NEXT_PUBLIC_ADMIN_PATH=/admin

# Application URLs
NEXT_PUBLIC_APP_URL=https://beingpersonalised.com
NODE_ENV=production

# Feature Flags (Optional)
NEXT_PUBLIC_ENABLE_FLOATING_WHATSAPP=true
NEXT_PUBLIC_ENABLE_MOBILE_QUICK_CONTACT=true
